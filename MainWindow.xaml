<Window x:Class="USDT_Sender.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:USDT_Sender"
    mc:Ignorable="d"
    Title="Crypto Flasher — Fake USDT Sender"
    Height="650" Width="1000"
    MinHeight="550" MinWidth="850"
    WindowStartupLocation="CenterScreen"
    xmlns:controls="clr-namespace:USDT_Sender.Controls"
    Background="#151517">


    <Window.Resources>

        <!-- ── Active nav indicator brush ── -->
        <SolidColorBrush x:Key="BrAccent" Color="#FF6C63FF" />
        <SolidColorBrush x:Key="BrTextMuted" Color="#FF8888A0" />
        <SolidColorBrush x:Key="BrTextOn" Color="#FFF0F0F5" />
        <SolidColorBrush x:Key="BrBorder" Color="#FF2E2E38" />
        <SolidColorBrush x:Key="BrCard" Color="#FF1E1E22" />

        <!-- ═══════════════════════════════════════════
             NAV BUTTON STYLE
             — Default: muted label, transparent bg
             — IsChecked (active): accent underline bar
        ════════════════════════════════════════════ -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="GroupName" Value="NavGroup" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <!-- Hover / active background pill -->
                            <Border x:Name="BgPill"
                                Background="Transparent"
                                CornerRadius="6"
                                Margin="4,6" />
                            <!-- Label -->
                            <TextBlock x:Name="Lbl"
                                Text="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontWeight="{TemplateBinding FontWeight}"
                                FontSize="{TemplateBinding FontSize}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
                            <!-- Active underline bar -->
                            <Border x:Name="Underline"
                                Height="2" Width="20"
                                CornerRadius="1"
                                Background="{StaticResource BrAccent}"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,0"
                                Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgPill" Property="Background" Value="#1A6C63FF" />
                                <Setter TargetName="Lbl" Property="Foreground"
                                    Value="{StaticResource BrTextOn}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground"
                                    Value="{StaticResource BrTextOn}" />
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter TargetName="BgPill" Property="Background" Value="#1A6C63FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon-only nav button (right side) ── -->
        <Style x:Key="NavIconBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A6C63FF" />
                                <Setter Property="Foreground" Value="{StaticResource BrTextOn}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════
         ROOT LAYOUT
    ══════════════════════════════════════════════════════ -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Nav Bar       -->
            <RowDefinition Height="Auto" />  <!-- Nav Divider   -->
            <RowDefinition Height="*" />     <!-- Content Area  -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════
             NAV BAR
        ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FF1E1E22" Height="60">
            <DockPanel Margin="16,0">

                <!-- LEFT: Branding -->
                <StackPanel DockPanel.Dock="Left"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,32,0">
                    <!-- Logo pill -->
                    <Border Width="34" Height="34" CornerRadius="9"
                        Background="{StaticResource BrAccent}"
                        Margin="0,0,10,0">
                        <TextBlock Text="B" FontFamily="Segoe UI"
                            FontWeight="SemiBold" FontSize="25"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Crypto Flasher" FontFamily="Segoe UI"
                            FontWeight="Bold" FontSize="15"
                            Foreground="#FFF0F0F5" />
                        <TextBlock Text="Fake USDT Sender" FontFamily="Segoe UI"
                            FontSize="10" Foreground="{StaticResource BrTextMuted}" />
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: Session info + icon actions -->
                <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0">

                    <!-- Live clock -->
                    <TextBlock x:Name="TxtClock"
                        FontFamily="Segoe UI" FontSize="11"
                        Foreground="{StaticResource BrTextMuted}"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0" />

                    <!-- Session badge -->
                    <Border x:Name="LicenseBadgeBorder"
                        Background="#2200D4AA"
                        BorderBrush="#FF00D4AA"
                        BorderThickness="1" CornerRadius="10"
                        Padding="10,3" Margin="0,0,16,0"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="LicenseDot"
                                Width="6" Height="6" Fill="#FFFF0000"
                                Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="LicenseBadgeText"
                                Text="NOT ACTIVATED" FontFamily="Segoe UI"
                                FontWeight="SemiBold" FontSize="10"
                                Foreground="#FFFF0000" />
                        </StackPanel>
                    </Border>
                    <!-- Notifications -->
                    <Button Style="{StaticResource NavIconBtn}"
                        ToolTip="Notifications"
                        Click="BtnNotifications_Click"
                        Margin="0,0,4,0">
                        <TextBlock Text="🔔" FontSize="15" />
                    </Button>

                    <!-- Settings -->
                    <Button Style="{StaticResource NavIconBtn}"
                        ToolTip="Settings"
                        Click="NavBtn_Click" Tag="Settings"
                        Margin="0,0,8,0">
                        <TextBlock Text="⚙" FontSize="15" />
                    </Button>

                    <!-- Cashier avatar -->
                    <Border Width="34" Height="34" CornerRadius="17"
                        Background="{StaticResource BrAccent}"
                        ToolTip="Cashier: Admin"
                        Cursor="Hand">
                        <TextBlock Text="CA" FontFamily="Segoe UI"
                            FontWeight="Bold" FontSize="12"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- CENTRE: Nav links -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <RadioButton x:Name="NavBilling"
                        Style="{StaticResource NavBtn}"
                        Content="Billing"
                        IsChecked="True"
                        ToolTip="Open billing terminal"
                        Checked="NavBtn_Checked" Tag="Billing" />

                    <RadioButton x:Name="NavReports"
                        Style="{StaticResource NavBtn}"
                        Content="Reports"
                        ToolTip="Sales reports and analytics"
                        Checked="NavBtn_Checked" Tag="Reports" />

                    <RadioButton x:Name="NavHelp"
                        Style="{StaticResource NavBtn}"
                        Content="Help"
                        ToolTip="Help and support"
                        Checked="NavBtn_Checked" Tag="Help" />

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Divider -->
        <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BrBorder}" />

        <!-- ══════════════════════════════════════════════
             CONTENT AREA  — views are swapped in here
        ══════════════════════════════════════════════════ -->
        <ContentControl x:Name="MainContent"
            Grid.Row="2"
            Focusable="False" />

        <!-- ── Global loader overlay ── -->
        <controls:UniversalLoader x:Name="AppLoader"
            Grid.RowSpan="3"
            Panel.ZIndex="998" />
        <!-- ── Global dialog overlay ── -->
        <controls:CustomDialog x:Name="AppDialog"
            Grid.RowSpan="3"
            Panel.ZIndex="999" />
    </Grid>
</Window>