<UserControl x:Class="USDT_Sender.Controls.CustomDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Visibility="Collapsed">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgOverlay"  Color="#CC0D0D10"/>
        <SolidColorBrush x:Key="BgCard"     Color="#FF18181F"/>
        <SolidColorBrush x:Key="BgInput"    Color="#FF1E1E28"/>
        <SolidColorBrush x:Key="Accent"     Color="#FF7B6EF6"/>
        <SolidColorBrush x:Key="Danger"     Color="#FFFF5C6E"/>
        <SolidColorBrush x:Key="Green"      Color="#FF2DD4BF"/>
        <SolidColorBrush x:Key="Warning"    Color="#FFFBBF24"/>
        <SolidColorBrush x:Key="TxtPrimary" Color="#FFF4F4F8"/>
        <SolidColorBrush x:Key="TxtMuted"   Color="#FF6B6B88"/>
        <SolidColorBrush x:Key="Border"     Color="#FF252535"/>

        <!-- Primary action button -->
        <Style x:Key="BtnAction" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost close button -->
        <Style x:Key="BtnClose" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TxtMuted}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource TxtPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Fullscreen dimmed overlay -->
    <Grid Background="{StaticResource BgOverlay}">

        <!-- Dialog card — centred -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="420" MaxWidth="520"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="36,32">
            <StackPanel>

                <!-- ── Icon + Header ── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <!-- Type icon badge -->
                    <Border x:Name="IconBadge"
                            Width="40" Height="40" CornerRadius="12"
                            Background="#1A7B6EF6" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="TxtIcon" Text="ℹ"
                                   FontSize="18"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Header text -->
                    <TextBlock x:Name="TxtHeader"
                               Text="Dialog Header"
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="17"
                               Foreground="{StaticResource TxtPrimary}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ── Divider ── -->
                <Rectangle Height="1" Fill="#FF1E1E2E" Margin="0,0,0,20"/>

                <!-- ── Message ── -->
                <TextBlock x:Name="TxtMessage"
                           Text="Dialog message goes here."
                           FontFamily="Segoe UI" FontSize="13" LineHeight="22"
                           Foreground="{StaticResource TxtMuted}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,28"/>

                <!-- ── Buttons ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnClose"
                            Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource BtnClose}"
                            Click="BtnClose_Click"/>

                    <Button x:Name="BtnAction"
                            Grid.Column="2"
                            Content="Confirm"
                            Style="{StaticResource BtnAction}"
                            Click="BtnAction_Click"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>