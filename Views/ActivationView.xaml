<UserControl x:Class="USDT_Sender.Views.ActivationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="clr-namespace:USDT_Sender.Controls"
    mc:Ignorable="d"
    d:DesignHeight="620" d:DesignWidth="600"
    Background="Transparent">

    <UserControl.Resources>
        <Storyboard x:Key="FadeInModal">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                From="0.0" To="1.0" Duration="0:0:0.4" />
        </Storyboard>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E1E22" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7B74FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A2D3A" />
                                <Setter Property="Foreground" Value="#555870" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12141E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Height" Value="48" />
            <Setter Property="BorderBrush" Value="#2E2E38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="20">
            <Border x:Name="ActiveBanner" Background="#1A00D4AA" BorderBrush="#FF00D4AA"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,20"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#FF00D4AA" VerticalAlignment="Center"
                        Margin="0,0,10,0" />
                    <TextBlock x:Name="ActiveBannerText" Foreground="#FF00D4AA" FontSize="13"
                        FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="License Key" Foreground="#8888A0" FontSize="11"
                        FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="KeyInput" Style="{StaticResource KeyBox}"
                        Text="BONTIX-XXXX-XXXX-XXXX" GotFocus="KeyInput_GotFocus" />
                    <TextBlock x:Name="ErrorText" Foreground="#FF5C7A" FontSize="12"
                        Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap" />
                    <Button x:Name="ActivateBtn" Content="Activate License"
                        Style="{StaticResource PrimaryBtn}" Margin="0,16,0,0"
                        Click="ActivateBtn_Click" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid x:Name="ModalOverlay" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource FadeInModal}" />
                            </Trigger.EnterActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="#CC0F0F13" />
            <Border Background="#1E1E22" CornerRadius="16" Padding="32" Width="480"
                HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#2E2E38"
                BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Verifying License" FontWeight="Bold" FontSize="16"
                        Foreground="#F0F0F5" Margin="0,0,0,4" />
                    <TextBlock x:Name="StatusLine" Foreground="#6B7099" FontSize="12"
                        Margin="0,0,0,24" Text="Connecting..." />

                    <ItemsControl x:Name="FileList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="55" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                        Foreground="#C5C9E8" FontFamily="Consolas" FontSize="12"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Size}"
                                        Foreground="#555870" FontSize="11"
                                        VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Margin="0,0,8,0" />
                                    <ProgressBar Grid.Column="2" Height="4"
                                        Value="{Binding Progress}" Maximum="100"
                                        Foreground="#6C63FF" Background="#12141E"
                                        BorderThickness="0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding StatusIcon}"
                                        FontFamily="Segoe MDL2 Assets"
                                        Foreground="{Binding StatusColor}" FontSize="14"
                                        VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="ResultText" FontSize="13" FontWeight="SemiBold"
                        Margin="0,16,0,0" Visibility="Collapsed" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Global loader overlay ── -->
        <controls:UniversalLoader x:Name="AppLoader"
            Grid.RowSpan="3"
            Panel.ZIndex="998" />
        <!-- ── Global dialog overlay ── -->
        <controls:CustomDialog x:Name="AppDialog"
            Grid.RowSpan="3"
            Panel.ZIndex="999" />

    </Grid>
</UserControl>