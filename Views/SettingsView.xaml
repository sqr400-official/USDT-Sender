<UserControl x:Class="USDT_Sender.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:USDT_Sender.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="#151517">

    <UserControl.Resources>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#6C63FF" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="#1E1E22" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F0F0F5" />
        </Style>

        <Style x:Key="RowSub" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#8888A0" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="42" Height="24"
                            CornerRadius="12" Background="#2E2E38">
                            <Border x:Name="Thumb" Width="18" Height="18"
                                CornerRadius="9" Background="#8888A0"
                                HorizontalAlignment="Left" Margin="3,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6C63FF" />
                                <Setter TargetName="Thumb" Property="Background" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                    Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#12141E" />
            <Setter Property="Foreground" Value="#F0F0F5" />
            <Setter Property="BorderBrush" Value="#2E2E38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Width" Value="150" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

            <!--
                COMBOBOX ITEM STYLE
                This controls how each option looks inside the open dropdown list.
                To change hover colour: edit IsHighlighted trigger → Background
                To change selected colour: edit IsSelected trigger → Background + Foreground
            -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F0F0F5" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="FontFamily" Value="Segoe UI" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBg"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background"
                                                Value="#2A2760" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background"
                                                Value="#1A1A6C63" />
                                            <Setter Property="Foreground" Value="#6C63FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>

            <!--
                COMBOBOX CONTROL TEMPLATE
                Two required parts WPF needs by name:
                  • PART_ToggleButton — MUST exist and be named exactly this.
                    It is what handles click-to-open/close. Without it, clicking
                    the combo does nothing. Keep it transparent and on top (ZIndex=1).
                  • PART_Popup — MUST exist and be named exactly this.
                    It is what WPF opens/closes when IsDropDownOpen changes.
                    Always bind IsOpen to {TemplateBinding IsDropDownOpen}.
                Any time you build a custom ComboBox template, include both of these
                named parts or the dropdown will not function.
            -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                            <!-- ↓ REQUIRED PART 1: handles click open/close.
                                 Keep transparent, ZIndex above the visual Border,
                                 Focusable=False so it doesn't steal keyboard focus. -->
                            <ToggleButton x:Name="PART_ToggleButton"
                                IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                ClickMode="Press"
                                Panel.ZIndex="1" />

                            <!-- Visual shell — the box the user sees when closed -->
                            <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <Grid Margin="12,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Displays the currently selected item's text.
                                         Must use SelectionBoxItem, NOT SelectedItem.
                                         IsHitTestVisible=False so clicks pass through
                                         to the PART_ToggleButton beneath it. -->
                                    <ContentPresenter Grid.Column="0"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        IsHitTestVisible="False" />

                                    <!-- Chevron arrow — IsHitTestVisible=False so clicks
                                         pass through to PART_ToggleButton beneath it -->
                                    <Path Grid.Column="1" x:Name="Arrow"
                                        Data="M0,0 L4,4 L8,0 Z"
                                        Fill="#8888A0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="8" Height="4"
                                        Stretch="Fill"
                                        IsHitTestVisible="False" />
                                </Grid>
                            </Border>

                            <!-- ↓ REQUIRED PART 2: the dropdown popup.
                                 Must be named PART_Popup exactly.
                                 IsOpen must bind to IsDropDownOpen on the templated parent.
                                 ItemsPresenter (not StackPanel) renders the items inside. -->
                            <Popup x:Name="PART_Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Fade">
                                <Border Background="#1A1A20"
                                    BorderBrush="#2E2E38"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    Margin="0,4,0,0">
                                    <ScrollViewer CanContentScroll="True" Padding="4">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6C63FF" />
                                <Setter TargetName="Arrow" Property="Fill" Value="#6C63FF" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6C63FF" />
                                <Setter TargetName="Arrow" Property="Fill" Value="#6C63FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#0A0A0F" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1E1E28" />
                                <Setter TargetName="Arrow" Property="Fill" Value="#333345" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,40">

            <!-- Page header -->
            <TextBlock Text="Settings" FontFamily="Segoe UI" FontWeight="Bold"
                FontSize="22" Foreground="#F0F0F5" Margin="0,0,0,6" />
            <TextBlock Text="Manage your application preferences and license."
                FontFamily="Segoe UI" FontSize="13" Foreground="#8888A0"
                Margin="0,0,0,36" />

            <!-- ROW 1 — full width: LICENSE ACTIVATION -->
            <TextBlock Text="LICENSE ACTIVATION" Style="{StaticResource SectionLabel}" />
            <Rectangle Height="1" Fill="#2E2E38" Margin="0,0,0,20" />
            <views:ActivationView />

            <!-- ROW 2 — two columns: GENERAL | APPEARANCE -->
            <Grid Margin="0,44,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: General -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}" />
                    <Rectangle Height="1" Fill="#2E2E38" Margin="0,0,0,4" />

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Default Receipt Printer"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Printer used for customer receipts."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <ComboBox Style="{StaticResource SettingCombo}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                SelectedIndex="0">
                                <ComboBoxItem Content="No Printer" />
                                <ComboBoxItem Content="PDF (Save to file)" />
                                <ComboBoxItem Content="Default System Printer" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Currency" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Symbol shown on bills and receipts."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <ComboBox Style="{StaticResource SettingCombo}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                SelectedIndex="0">
                                <ComboBoxItem Content="NGN — ₦" />
                                <ComboBoxItem Content="USD — $" />
                                <ComboBoxItem Content="EUR — €" />
                                <ComboBoxItem Content="GBP — £" />
                                <ComboBoxItem Content="GHS — ₵" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Auto-print Receipt"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Print receipt after every completed sale."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource Toggle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                IsChecked="True" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Appearance -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionLabel}" />
                    <Rectangle Height="1" Fill="#2E2E38" Margin="0,0,0,4" />

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Theme" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Choose the application colour theme."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <ComboBox Style="{StaticResource SettingCombo}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                SelectedIndex="0">
                                <ComboBoxItem Content="Dark (default)" />
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="System default" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Compact Mode" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Reduce spacing and padding throughout the UI."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource Toggle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Show Clock in Nav Bar"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Display the live time in the top navigation bar."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource Toggle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                IsChecked="True" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ROW 3 — two columns: SESSION | ABOUT -->
            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Session -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SESSION" Style="{StaticResource SectionLabel}" />
                    <Rectangle Height="1" Fill="#2E2E38" Margin="0,0,0,4" />

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Cashier Name" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Shown on receipts and the nav bar avatar."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#12141E" BorderBrush="#2E2E38"
                                BorderThickness="1" CornerRadius="8" Width="150" Height="34">
                                <TextBox Background="Transparent" Foreground="#F0F0F5"
                                    BorderThickness="0" FontFamily="Segoe UI" FontSize="12"
                                    VerticalContentAlignment="Center" Padding="10,0"
                                    CaretBrush="White" Text="Admin" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Auto-lock After Inactivity"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Lock the terminal automatically when idle."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <ComboBox Style="{StaticResource SettingCombo}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                SelectedIndex="0">
                                <ComboBoxItem Content="Never" />
                                <ComboBoxItem Content="5 minutes" />
                                <ComboBoxItem Content="15 minutes" />
                                <ComboBoxItem Content="30 minutes" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Launch on Startup"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Launch BonTix when the computer starts."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource Toggle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                IsChecked="True" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- RIGHT: About -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionLabel}" />
                    <Rectangle Height="1" Fill="#2E2E38" Margin="0,0,0,4" />

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Application Version"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Current installed build of BonTix."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <TextBlock Text="v1.0.0" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Foreground="#8888A0"
                                FontFamily="Consolas" FontSize="12" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Check for Updates"
                                    Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Automatically check for new versions on launch."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource Toggle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                IsChecked="True" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Support" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="Contact BonTix support for help."
                                    Style="{StaticResource RowSub}" />
                            </StackPanel>
                            <TextBlock Text="support@bontix.app" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Foreground="#6C63FF"
                                FontFamily="Segoe UI" FontSize="12"
                                Cursor="Hand" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Height="40" />
        </StackPanel>
    </ScrollViewer>
</UserControl>