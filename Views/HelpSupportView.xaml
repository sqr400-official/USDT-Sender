<UserControl x:Class="USDT_Sender.Views.HelpSupportView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  mc:Ignorable="d"
  d:DesignHeight="900" d:DesignWidth="1000">

  <UserControl.Resources>
    <!-- 🎨 PALETTE - Reused from BillingView for consistency -->
    <SolidColorBrush x:Key="BgPanel" Color="#FF13131A" />
    <SolidColorBrush x:Key="BgCard" Color="#FF18181F" />
    <SolidColorBrush x:Key="BgInput" Color="#FF1E1E28" />
    <SolidColorBrush x:Key="BgInputHover" Color="#FF23232E" />
    <SolidColorBrush x:Key="Accent" Color="#FF7B6EF6" />
    <SolidColorBrush x:Key="AccentSoft" Color="#FF9D93F8" />
    <SolidColorBrush x:Key="Green" Color="#FF2DD4BF" />
    <SolidColorBrush x:Key="Danger" Color="#FFFF5C6E" />
    <SolidColorBrush x:Key="Warning" Color="#FFFBBF24" />
    <SolidColorBrush x:Key="TxtPrimary" Color="#FFF4F4F8" />
    <SolidColorBrush x:Key="TxtSecondary" Color="#FFB0B0C8" />
    <SolidColorBrush x:Key="TxtMuted" Color="#FF6B6B88" />
    <SolidColorBrush x:Key="Border" Color="#FF252535" />
    <SolidColorBrush x:Key="Separator" Color="#FF1E1E2E" />

    <!-- 🌈 GRADIENT BACKGROUND -->
    <LinearGradientBrush x:Key="PageGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0D0D10" Offset="0.0" />
      <GradientStop Color="#12121A" Offset="0.35" />
      <GradientStop Color="#1A1A2E" Offset="0.7" />
      <GradientStop Color="#16213E" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ✨ SHADOW EFFECTS -->
    <DropShadowEffect x:Key="CardShadow" Color="#7B6EF6" Direction="270" ShadowDepth="0"
      BlurRadius="24" Opacity="0.15" />
    <DropShadowEffect x:Key="InputGlow" Color="#2DD4BF" Direction="0" ShadowDepth="0"
      BlurRadius="12" Opacity="0.08" />

    <!-- 🔑 KEYBOX INPUT STYLE -->
    <Style x:Key="KeyBox" TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource BgInput}" />
      <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
      <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Effect" Value="{StaticResource InputGlow}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="12">
              <Grid>
                <ScrollViewer x:Name="PART_ContentHost"
                  Margin="{TemplateBinding Padding}"
                  VerticalAlignment="Center" />
                <TextBlock x:Name="Placeholder"
                  Text="{TemplateBinding Tag}"
                  Foreground="{StaticResource TxtMuted}"
                  FontFamily="Segoe UI" FontSize="14"
                  Margin="16,0,0,0"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False"
                  Visibility="Collapsed" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgInputHover}" />
              </Trigger>
              <Trigger Property="Text" Value="">
                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 💬 MESSAGE BOX (for contact form) -->
    <Style x:Key="MessageBox" TargetType="TextBox" BasedOn="{StaticResource KeyBox}">
      <Setter Property="Height" Value="120" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <!-- 📋 FIELD LABEL -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TxtMuted}" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- 🗂️ ACCORDION HEADER (Expander styling) -->
    <Style x:Key="FaqExpander" TargetType="Expander">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,0,0,16" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Expander">
            <Border BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              Background="{TemplateBinding Background}">
              <DockPanel>
                <ToggleButton x:Name="HeaderToggle"
                  DockPanel.Dock="Top"
                  Content="{TemplateBinding Header}"
                  Background="Transparent"
                  BorderThickness="0"
                  IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                  Cursor="Hand"
                  Padding="0,16,0,12">
                  <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                      <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>

                        <Label x:Name="HeaderText"
                          Grid.Column="0"
                          Content="{TemplateBinding Content}"
                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Expander}}"
                          VerticalAlignment="Center"
                          Padding="0"
                          Margin="0,0,8,0" />

                        <TextBlock x:Name="RotateIconText"
                          Grid.Column="1"
                          Text="+"
                          FontSize="20"
                          FontWeight="Bold"
                          Foreground="{StaticResource Accent}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5">
                          <TextBlock.RenderTransform>
                            <RotateTransform x:Name="RotateIcon" Angle="0" />
                          </TextBlock.RenderTransform>
                        </TextBlock>
                      </Grid>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                          <Setter TargetName="HeaderText" Property="Foreground"
                            Value="{StaticResource Accent}" />

                          <Trigger.EnterActions>
                            <BeginStoryboard>
                              <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateIcon"
                                  Storyboard.TargetProperty="Angle"
                                  To="45" Duration="0:0:0.15" />
                              </Storyboard>
                            </BeginStoryboard>
                          </Trigger.EnterActions>
                          <Trigger.ExitActions>
                            <BeginStoryboard>
                              <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateIcon"
                                  Storyboard.TargetProperty="Angle"
                                  To="0" Duration="0:0:0.15" />
                              </Storyboard>
                            </BeginStoryboard>
                          </Trigger.ExitActions>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </ToggleButton.Template>
                </ToggleButton>

                <ContentPresenter x:Name="ContentSite"
                  DockPanel.Dock="Bottom"
                  Content="{TemplateBinding Content}"
                  ContentTemplate="{TemplateBinding ContentTemplate}"
                  Visibility="Collapsed"
                  Margin="0,8,24,0" />
              </DockPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 🔗 HYPERLINK BUTTON -->
    <Style x:Key="LinkButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource Accent}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <TextBlock Text="{TemplateBinding Content}"
              Foreground="{TemplateBinding Foreground}"
              FontFamily="{TemplateBinding FontFamily}"
              FontSize="{TemplateBinding FontSize}"
              TextDecorations="Underline" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource AccentSoft}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 🎯 PRIMARY BUTTON -->
    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Effect" Value="{StaticResource CardShadow}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                <Setter Property="Effect" Value="{x:Null}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ✅ VALIDATION BADGE -->
    <Style x:Key="ValOk" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Green}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Resources>

  <!-- 🎨 MAIN LAYOUT -->
  <ScrollViewer VerticalScrollBarVisibility="Auto"
    HorizontalScrollBarVisibility="Disabled"
    Background="{StaticResource PageGradient}">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="920" MaxWidth="920" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- 🖼️ Subtle Background Pattern -->
      <Image Grid.ColumnSpan="3"
        Source="/USDT_Sender;component/Assets/crypto-pattern.png"
        Stretch="UniformToFill"
        Opacity="0.04"
        IsHitTestVisible="False"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Margin="0,-100,0,0" />

      <StackPanel Grid.Column="1" Margin="0,40,0,64">

        <!-- 🧭 HEADER -->
        <StackPanel Margin="0,0,0,32">
          <Border Background="#1A7B6EF6" CornerRadius="20" Padding="10,4"
            HorizontalAlignment="Left" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}"
                VerticalAlignment="Center" Margin="0,0,7,0" />
              <TextBlock Text="SUPPORT CENTER" FontFamily="Segoe UI"
                FontWeight="Bold" FontSize="10"
                Foreground="{StaticResource Accent}" />
            </StackPanel>
          </Border>
          <TextBlock Text="Help &amp; Support" FontFamily="Segoe UI" FontWeight="Bold"
            FontSize="32" Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,8" />
          <TextBlock FontFamily="Segoe UI" FontSize="13" LineHeight="22"
            Foreground="{StaticResource TxtSecondary}">
            Get answers, submit a ticket, or chat with our team.
          </TextBlock>
        </StackPanel>

        <!-- 🚀 EXTRA: QUICK ACTIONS PANEL -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="18" Padding="24,20" Margin="0,0,0,28"
          Effect="{StaticResource CardShadow}">
          <StackPanel>
            <TextBlock Text="⚡ Quick Actions" FontFamily="Segoe UI" FontWeight="SemiBold"
              FontSize="13" Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,16" />
            <UniformGrid Columns="3" Rows="1">
              <Button Style="{StaticResource LinkButton}" Content="📧 Check Ticket Status"
                Margin="0,0,12,0" Click="BtnQuickAction_Click" Tag="status" />
              <Button Style="{StaticResource LinkButton}" Content="💬 Live Chat"
                Margin="0,0,12,0" Click="BtnQuickAction_Click" Tag="chat" />
              <Button Style="{StaticResource LinkButton}" Content="📚 User Guides"
                Click="BtnQuickAction_Click" Tag="guides" />
            </UniformGrid>
          </StackPanel>
        </Border>

        <!-- 📬 CONTACT FORM CARD -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="24" Padding="44,40" Margin="0,0,0,28"
          Effect="{StaticResource CardShadow}">
          <StackPanel>
            <TextBlock Text="📬 Contact Us" FontFamily="Segoe UI" FontWeight="Bold"
              FontSize="18" Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,24" />

            <!-- Name -->
            <StackPanel Margin="0,0,0,20">
              <TextBlock Text="YOUR NAME" Style="{StaticResource FieldLabel}" />
              <TextBox x:Name="TxtContactName" Style="{StaticResource KeyBox}"
                Tag="Enter your full name" TextChanged="TxtContactName_TextChanged" />
              <TextBlock x:Name="ErrName" Text="Please enter your name."
                Style="{StaticResource ValOk}" Foreground="{StaticResource Danger}"
                Visibility="Collapsed" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Email -->
            <StackPanel Margin="0,0,0,20">
              <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}" />
              <TextBox x:Name="TxtContactEmail" Style="{StaticResource KeyBox}"
                Tag="you@example.com" TextChanged="TxtContactEmail_TextChanged" />
              <TextBlock x:Name="ErrEmail" Text="Please enter a valid email."
                Style="{StaticResource ValOk}" Foreground="{StaticResource Danger}"
                Visibility="Collapsed" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Subject -->
            <StackPanel Margin="0,0,0,20">
              <TextBlock Text="SUBJECT" Style="{StaticResource FieldLabel}" />
              <TextBox x:Name="TxtContactSubject" Style="{StaticResource KeyBox}"
                Tag="Brief description of your issue" TextChanged="TxtContactSubject_TextChanged" />
              <TextBlock x:Name="ErrSubject" Text="Please enter a subject."
                Style="{StaticResource ValOk}" Foreground="{StaticResource Danger}"
                Visibility="Collapsed" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Message -->
            <StackPanel Margin="0,0,0,28">
              <TextBlock Text="MESSAGE" Style="{StaticResource FieldLabel}" />
              <TextBox x:Name="TxtContactMessage" Style="{StaticResource MessageBox}"
                Tag="Describe your issue in detail..." TextChanged="TxtContactMessage_TextChanged" />
              <TextBlock x:Name="ErrMessage" Text="Message must be at least 20 characters."
                Style="{StaticResource ValOk}" Foreground="{StaticResource Danger}"
                Visibility="Collapsed" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Send Button -->
            <Button x:Name="BtnSendTicket" Style="{StaticResource BtnPrimary}"
              Content="📤 Send Support Ticket" IsEnabled="False"
              Click="BtnSendTicket_Click" HorizontalAlignment="Stretch" />

            <!-- Success Message -->
            <TextBlock x:Name="TxtSendSuccess" Text="✓ Ticket sent! We'll reply within 24 hours."
              Foreground="{StaticResource Green}" FontSize="13"
              Visibility="Collapsed" Margin="0,16,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- ❓ FAQ ACCORDION CARD -->
        <Border
          Background="{StaticResource BgCard}"
          BorderBrush="{StaticResource Border}"
          BorderThickness="1"
          CornerRadius="24"
          Padding="44,40"
          Margin="0,0,0,28"
          Effect="{StaticResource CardShadow}"
        >
          <StackPanel>
            <TextBlock
              Text="❓ Frequently Asked Questions"
              FontFamily="Segoe UI"
              FontWeight="Bold"
              FontSize="24"
              Foreground="{StaticResource TxtPrimary}"
              Margin="0,0,0,24"
            />

            <Expander
              Style="{StaticResource FaqExpander}"
              Header="How long do USDT transactions take?"
              FontSize="16"
              FontWeight="SemiBold"
              Foreground="{StaticResource TxtSecondary}"
            >
              <TextBlock
                FontFamily="Segoe UI"
                FontSize="13"
                Foreground="{StaticResource TxtSecondary}"
                TextWrapping="Wrap"
                LineHeight="20"
              >
                <Run FontWeight="SemiBold">TRC-20:</Run> Typically 1-3 minutes.<LineBreak />
                <Run
                  FontWeight="SemiBold">
                  ERC-20:
                </Run> Usually 5-15 minutes, depending
                on Ethereum network congestion.<LineBreak />
                <Run FontWeight="SemiBold">
                  Note:
                </Run> Always wait for the required
                number of confirmations before considering a transaction final. </TextBlock>
            </Expander>

            <Expander
              Style="{StaticResource FaqExpander}"
              Header="What if I sent funds to the wrong address?"
              FontSize="16"
              FontWeight="SemiBold"
              Foreground="{StaticResource TxtSecondary}"
            >
              <TextBlock
                FontFamily="Segoe UI"
                FontSize="13"
                Foreground="{StaticResource TxtSecondary}"
                TextWrapping="Wrap"
                LineHeight="20"> Cryptocurrency transactions are irreversible. <Run
                  FontWeight="SemiBold">Always double-check</Run> the wallet address and network
                before sending. If you made an error, contact our support team immediately with the
                transaction ID—we may be able to assist in rare cases. </TextBlock>
            </Expander>

            <Expander
              Style="{StaticResource FaqExpander}"
              Header="How are exchange rates calculated?"
              FontSize="16"
              FontWeight="SemiBold"
              Foreground="{StaticResource TxtSecondary}"
            >
              <TextBlock FontFamily="Segoe UI" FontSize="13"
                Foreground="{StaticResource TxtSecondary}"
                TextWrapping="Wrap" LineHeight="20">
                Rates are pulled in real-time from multiple liquidity providers and include a small
                service margin.
                The exact rate is locked at the moment you confirm payment and is displayed before
                final submission.
              </TextBlock>
            </Expander>

            <Expander Style="{StaticResource FaqExpander}" Header="Is my data secure?"
              FontSize="16"
              FontWeight="SemiBold"
              Foreground="{StaticResource TxtSecondary}"
            >
              <TextBlock FontFamily="Segoe UI" FontSize="13"
                Foreground="{StaticResource TxtSecondary}"
                TextWrapping="Wrap" LineHeight="20"> Yes. We use end-to-end encryption, never store
                private keys, and comply with GDPR/CCPA. All sensitive operations require 2FA
                verification. Learn more in our <Hyperlink
                  NavigateUri="https://usdt-sender.com/privacy"
                  RequestNavigate="Hyperlink_RequestNavigate">Privacy Policy</Hyperlink>. </TextBlock>
            </Expander>

            <Expander Style="{StaticResource FaqExpander}" Header="How do I track my ticket?"
              FontSize="16"
              FontWeight="SemiBold"
              Foreground="{StaticResource TxtSecondary}"
            >
              <TextBlock FontFamily="Segoe UI" FontSize="13"
                Foreground="{StaticResource TxtSecondary}"
                TextWrapping="Wrap" LineHeight="20">
                After submitting a ticket, you'll receive a confirmation email with a unique ticket
                ID.
                Use the "Check Ticket Status" quick action above or visit our support portal with
                your ID.
              </TextBlock>
            </Expander>
          </StackPanel>
        </Border>

        <!-- 🔗 WEBSITE & SOCIAL LINKS -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="18" Padding="28,24" Effect="{StaticResource CardShadow}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
              <TextBlock Text="🌐 Visit Our Website" FontFamily="Segoe UI" FontWeight="SemiBold"
                FontSize="13" Foreground="{StaticResource TxtPrimary}" VerticalAlignment="Center" />
              <Button Style="{StaticResource LinkButton}" Content="usdt-sender.com"
                Margin="12,0,0,0" Click="BtnWebsite_Click" />
            </StackPanel>

            <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,8,0,16" />

            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Follow us:" FontFamily="Segoe UI" FontSize="12"
                Foreground="{StaticResource TxtMuted}" VerticalAlignment="Center" Margin="0,0,12,0" />
              <Button Style="{StaticResource LinkButton}" Content="𝕏" FontSize="14"
                Margin="0,0,8,0" Click="BtnSocial_Click" Tag="twitter" />
              <Button Style="{StaticResource LinkButton}" Content="in" FontSize="14"
                Margin="0,0,8,0" Click="BtnSocial_Click" Tag="linkedin" />
              <Button Style="{StaticResource LinkButton}" Content="▶" FontSize="14"
                Click="BtnSocial_Click" Tag="youtube" />
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>