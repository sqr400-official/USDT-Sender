<UserControl x:Class="USDT_Sender.Views.ReportsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:USDT_Sender.Views"
  mc:Ignorable="d"
  d:DesignHeight="1000" d:DesignWidth="1200">

  <UserControl.Resources>
    <!-- 🎨 COLOR PALETTE - All colors used in the view -->
    <SolidColorBrush x:Key="BgPanel" Color="#FF13131A" />
    <SolidColorBrush x:Key="BgCard" Color="#FF18181F" />
    <SolidColorBrush x:Key="BgInput" Color="#FF1E1E28" />
    <SolidColorBrush x:Key="BgInputHover" Color="#FF23232E" />
    <SolidColorBrush x:Key="Accent" Color="#FF7B6EF6" />
    <SolidColorBrush x:Key="AccentSoft" Color="#FF9D93F8" />
    <SolidColorBrush x:Key="Green" Color="#FF2DD4BF" />
    <SolidColorBrush x:Key="Danger" Color="#FFFF5C6E" />
    <SolidColorBrush x:Key="Warning" Color="#FFFBBF24" />
    <SolidColorBrush x:Key="TxtPrimary" Color="#FFF4F4F8" />
    <SolidColorBrush x:Key="TxtSecondary" Color="#FFB0B0C8" />
    <SolidColorBrush x:Key="TxtMuted" Color="#FF6B6B88" />
    <SolidColorBrush x:Key="Border" Color="#FF252535" />
    <SolidColorBrush x:Key="Separator" Color="#FF1E1E2E" />

    <!-- 🌈 GRADIENT BACKGROUND -->
    <LinearGradientBrush x:Key="PageGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0D0D10" Offset="0.0" />
      <GradientStop Color="#12121A" Offset="0.35" />
      <GradientStop Color="#1A1A2E" Offset="0.7" />
      <GradientStop Color="#16213E" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ✨ SHADOW EFFECTS -->
    <DropShadowEffect x:Key="CardShadow" Color="#7B6EF6" Direction="270" ShadowDepth="0"
      BlurRadius="24" Opacity="0.15" />
    <DropShadowEffect x:Key="InputGlow" Color="#2DD4BF" Direction="0" ShadowDepth="0"
      BlurRadius="12" Opacity="0.08" />

    <!-- 🔄 CONVERTERS -->
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    <local:PercentToHeightConverter x:Key="PercentToHeight" />
    <local:TruncateConverter x:Key="TruncateConverter" />

    <!-- 🔑 TEXTBOX STYLE -->
    <Style x:Key="KeyBox" TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource BgInput}" />
      <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
      <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Effect" Value="{StaticResource InputGlow}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="12">
              <Grid>
                <ScrollViewer x:Name="PART_ContentHost"
                  Margin="{TemplateBinding Padding}"
                  VerticalAlignment="Center" />
                <TextBlock x:Name="Placeholder"
                  Text="{TemplateBinding Tag}"
                  Foreground="{StaticResource TxtMuted}"
                  FontFamily="Segoe UI" FontSize="14"
                  Margin="16,0,0,0"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False"
                  Visibility="Collapsed" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgInputHover}" />
              </Trigger>
              <Trigger Property="Text" Value="">
                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 🎯 PRIMARY BUTTON STYLE -->
    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Height" Value="44" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Effect" Value="{StaticResource CardShadow}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                <Setter Property="Effect" Value="{x:Null}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 🔗 OUTLINE BUTTON STYLE -->
    <Style x:Key="BtnOutline" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Height" Value="44" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="20,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgInputHover}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 🏷️ STATUS BADGE STYLE -->
    <Style x:Key="StatusBadge" TargetType="Border">
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- 📊 DATA GRID STYLE -->
    <Style x:Key="ReportsDataGrid" TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="RowHeight" Value="64" />
      <Setter Property="AlternatingRowBackground" Value="#FF1A1A22" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Separator}" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserResizeColumns" Value="True" />
      <Setter Property="CanUserSortColumns" Value="True" />
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="SelectionUnit" Value="FullRow" />

      <!-- Column Header Style -->
      <Setter Property="ColumnHeaderStyle">
        <Setter.Value>
          <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TxtMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{StaticResource Separator}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
          </Style>
        </Setter.Value>
      </Setter>

      <!-- Row Style -->
      <Setter Property="RowStyle">
        <Setter.Value>
          <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,8" />
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1A7B6EF6" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF1E1E28" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>

      <!-- Cell Style -->
      <Setter Property="CellStyle">
        <Setter.Value>
          <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                  <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 📈 SUMMARY CARD STYLE -->
    <Style x:Key="SummaryCard" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource BgCard}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="20,16" />
      <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <!-- 🔗 ICON BUTTON STYLE -->
    <Style x:Key="LinkButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="Foreground" Value="{StaticResource TxtMuted}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
              Padding="{TemplateBinding Padding}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgInput}" />
                <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>


    <Style x:Key="FieldCombo" TargetType="ComboBox">
      <Setter Property="Background" Value="{StaticResource BgCard }" />
      <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
      <Setter Property="BorderBrush" Value="{StaticResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="Effect" Value="{StaticResource InputGlow}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                  </Grid.ColumnDefinitions>
                  <ContentPresenter x:Name="ContentSite"
                    Grid.Column="0"
                    Content="{TemplateBinding SelectionBoxItem}"
                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                    Margin="{TemplateBinding Padding}"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />
                  <TextBlock Grid.Column="1"
                    Text="⌄"
                    FontSize="14"
                    Foreground="{StaticResource TxtMuted}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
                  <ToggleButton Grid.ColumnSpan="2"
                    IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"
                    Background="Transparent"
                    BorderThickness="0"
                    Focusable="False" />
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup"
                IsOpen="{TemplateBinding IsDropDownOpen}"
                AllowsTransparency="True"
                Focusable="False"
                PopupAnimation="Fade"
                Placement="Bottom">
                <Border x:Name="DropBorder"
                  MinWidth="{TemplateBinding ActualWidth}"
                  MaxHeight="240"
                  Background="#FF1E1E28"
                  BorderBrush="{StaticResource Border}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Margin="0,4,0,0"
                  Effect="{StaticResource CardShadow}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush"
                  Value="{StaticResource Accent}" />
              </Trigger>
              <Trigger Property="IsDropDownOpen" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush"
                  Value="{StaticResource Accent}" />
                <Setter TargetName="Bd" Property="Background"
                  Value="{StaticResource BgInputHover}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                  <Border x:Name="ItemBd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="8"
                    Margin="6,3">
                    <ContentPresenter VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                      <Setter TargetName="ItemBd" Property="Background"
                        Value="#FF252535" />
                      <Setter Property="Foreground"
                        Value="{StaticResource TxtPrimary}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="ItemBd" Property="Background"
                        Value="#1A7B6EF6" />
                      <Setter Property="Foreground"
                        Value="{StaticResource AccentSoft}" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>


  </UserControl.Resources>

  <!-- 🎨 MAIN LAYOUT -->
  <ScrollViewer VerticalScrollBarVisibility="Auto"
    HorizontalScrollBarVisibility="Disabled"
    Background="{StaticResource PageGradient}">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="1100" MaxWidth="1100" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="1" Margin="0,40,0,64">

        <!-- 🧭 HEADER -->
        <StackPanel Margin="0,0,0,28">
          <Border Background="#1A7B6EF6" CornerRadius="20" Padding="10,4"
            HorizontalAlignment="Left" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}"
                VerticalAlignment="Center" Margin="0,0,7,0" />
              <TextBlock Text="ANALYTICS" FontFamily="Segoe UI"
                FontWeight="Bold" FontSize="10"
                Foreground="{StaticResource Accent}" />
            </StackPanel>
          </Border>
          <TextBlock Text="Transaction Reports" FontFamily="Segoe UI" FontWeight="Bold"
            FontSize="32" Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,8" />
          <TextBlock FontFamily="Segoe UI" FontSize="13" LineHeight="22"
            Foreground="{StaticResource TxtSecondary}">
            Track, filter, and export your USDT transaction history.
          </TextBlock>
        </StackPanel>

        <!-- 📊 SUMMARY CARDS ROW -->
        <Grid Margin="0,0,0,28">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Total Sent -->
          <Border Grid.Column="0" Style="{StaticResource SummaryCard}" Margin="0,0,8,0">
            <StackPanel>
              <TextBlock Text="Total Sent" FontFamily="Segoe UI" FontSize="11"
                Foreground="{StaticResource TxtMuted}" FontWeight="SemiBold" />
              <TextBlock x:Name="TxtTotalSent" Text="$0.00" FontFamily="Consolas"
                FontSize="24" FontWeight="Bold" Foreground="{StaticResource TxtPrimary}"
                Margin="0,8,0,0" />
              <TextBlock x:Name="TxtTotalSentChange" Text="+0% vs last month"
                FontSize="10" Foreground="{StaticResource Green}" Margin="0,4,0,0" />
            </StackPanel>
          </Border>

          <!-- Pending -->
          <Border Grid.Column="1" Style="{StaticResource SummaryCard}" Margin="4,0">
            <StackPanel>
              <TextBlock Text="Pending" FontFamily="Segoe UI" FontSize="11"
                Foreground="{StaticResource TxtMuted}" FontWeight="SemiBold" />
              <TextBlock x:Name="TxtPendingCount" Text="0" FontFamily="Consolas"
                FontSize="24" FontWeight="Bold" Foreground="{StaticResource Warning}"
                Margin="0,8,0,0" />
              <TextBlock Text="Transactions" FontSize="10"
                Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0" />
            </StackPanel>
          </Border>

          <!-- Completed -->
          <Border Grid.Column="2" Style="{StaticResource SummaryCard}" Margin="4,0">
            <StackPanel>
              <TextBlock Text="Completed" FontFamily="Segoe UI" FontSize="11"
                Foreground="{StaticResource TxtMuted}" FontWeight="SemiBold" />
              <TextBlock x:Name="TxtCompletedCount" Text="0" FontFamily="Consolas"
                FontSize="24" FontWeight="Bold" Foreground="{StaticResource Green}"
                Margin="0,8,0,0" />
              <TextBlock Text="Transactions" FontSize="10"
                Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0" />
            </StackPanel>
          </Border>

          <!-- Failed -->
          <Border Grid.Column="3" Style="{StaticResource SummaryCard}" Margin="8,0,0,0">
            <StackPanel>
              <TextBlock Text="Failed" FontFamily="Segoe UI" FontSize="11"
                Foreground="{StaticResource TxtMuted}" FontWeight="SemiBold" />
              <TextBlock x:Name="TxtFailedCount" Text="0" FontFamily="Consolas"
                FontSize="24" FontWeight="Bold" Foreground="{StaticResource Danger}"
                Margin="0,8,0,0" />
              <TextBlock Text="Transactions" FontSize="10"
                Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0" />
            </StackPanel>
          </Border>
        </Grid>

        <!-- 🔍 FILTER & EXPORT BAR -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="18" Padding="24,20" Margin="0,0,0,28"
          Effect="{StaticResource CardShadow}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Filters -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <!-- Search -->
              <TextBox x:Name="TxtSearch" Style="{StaticResource KeyBox}"
                Tag="Search by TXID, wallet, or amount..."
                Width="280" Margin="0,0,16,0"
                TextChanged="TxtSearch_TextChanged" />


              <!-- Status Filter -->
              <ComboBox
                x:Name="CmbStatusFilter"
                Style="{StaticResource FieldCombo}"
                Width="140" Height="48"
                Background="{StaticResource BgInput}" Foreground="{StaticResource TxtPrimary}"
                BorderBrush="{StaticResource Border}" BorderThickness="1"
                FontFamily="Segoe UI" FontSize="13" Padding="14,0"
                VerticalContentAlignment="Center"
                SelectionChanged="CmbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="All Status" IsSelected="True" />
                <ComboBoxItem Content="Completed" />
                <ComboBoxItem Content="Pending" />
                <ComboBoxItem Content="Failed" />
              </ComboBox>
            </StackPanel>

            <!-- Export Buttons -->
            <StackPanel Orientation="Horizontal" Grid.Column="1">
              <Button
                x:Name="BtnExportCsv"
                Style="{StaticResource BtnOutline}"
                Content="📄 Export CSV"
                Margin="0,0,12,0"
                Width="150"
                Click="BtnExportCsv_Click"
              />
              <Button
                x:Name="BtnExportPdf"
                Style="{StaticResource BtnPrimary}"
                Width="150"
                Content="📊 Export PDF"
                Click="BtnExportPdf_Click"
              />
            </StackPanel>
          </Grid>
        </Border>

        <!-- 📋 TRANSACTION DATA GRID -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="24" Padding="8" Margin="0,0,0,28"
          Effect="{StaticResource CardShadow}">

          <Grid>
            <!-- Header -->
            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
            </Grid>

            <!-- DataGrid -->
            <DataGrid x:Name="DgTransactions" Style="{StaticResource ReportsDataGrid}"
              ItemsSource="{Binding Transactions}"
              CanUserAddRows="False" CanUserDeleteRows="False"
              AutoGenerateColumns="False"
              SelectionChanged="DgTransactions_SelectionChanged">

              <DataGrid.Columns>
                <!-- Date -->
                <DataGridTextColumn Header="Date"
                  Binding="{Binding Date, StringFormat='MMM dd, HH:mm'}"
                  Width="140" FontWeight="SemiBold" />

                <!-- Type -->
                <DataGridTextColumn Header="Type" Binding="{Binding Type}"
                  Width="100" />

                <!-- Amount -->
                <DataGridTextColumn Header="Amount"
                  Binding="{Binding Amount, StringFormat='N2'}"
                  Width="110" FontWeight="SemiBold" />

                <!-- Crypto -->
                <DataGridTextColumn Header="Asset" Binding="{Binding Crypto}"
                  Width="120" />

                <!-- Status Badge -->
                <DataGridTemplateColumn Header="Status" Width="110">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Center">
                        <Border.Style>
                          <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Status}" Value="Completed">
                                <Setter Property="Background" Value="#1A2DD4BF" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Status}" Value="Pending">
                                <Setter Property="Background" Value="#1AFBBF24" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Status}" Value="Failed">
                                <Setter Property="Background" Value="#1AFF5C6E" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>

                        <TextBlock Text="{Binding Status}"
                          FontSize="11"
                          FontWeight="SemiBold"
                          HorizontalAlignment="Center">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                  <Setter Property="Foreground" Value="{StaticResource Green}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                  <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                  <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- TXID (truncated) -->
                <DataGridTextColumn Header="Transaction ID"
                  Binding="{Binding Txid, Converter={StaticResource TruncateConverter}, ConverterParameter=12}"
                  Width="140" Foreground="{StaticResource TxtMuted}" FontFamily="Consolas"
                  FontSize="11" />

                <!-- Actions -->
                <DataGridTemplateColumn Header="" Width="140">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Copy TXID -->
                        <Button Style="{StaticResource LinkButton}" Content="📋"
                          ToolTip="Copy TXID" FontSize="13"
                          Margin="0,0,8,0"
                          Click="BtnCopyTxid_Click"
                          Tag="{Binding Txid}" />
                        <!-- View Explorer -->
                        <Button Style="{StaticResource LinkButton}" Content="🔍"
                          ToolTip="View on Explorer" FontSize="13"
                          Margin="0,0,8,0"
                          Click="BtnViewExplorer_Click"
                          Tag="{Binding Txid}" />
                        <!-- Retry (only for failed) -->
                        <Button Style="{StaticResource LinkButton}" Content="🔄"
                          ToolTip="Retry Transaction" FontSize="13"
                          Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}"
                          Click="BtnRetryTransaction_Click"
                          Tag="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State -->
            <StackPanel x:Name="PnlEmptyState" HorizontalAlignment="Center"
              VerticalAlignment="Center" Visibility="Collapsed" Margin="0,40">
              <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" />
              <TextBlock Text="No transactions found" FontFamily="Segoe UI" FontSize="16"
                Foreground="{StaticResource TxtPrimary}" FontWeight="SemiBold"
                HorizontalAlignment="Center" Margin="0,0,0,8" />
              <TextBlock Text="Try adjusting your filters or make your first transaction."
                FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TxtSecondary}"
                HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- 📈 VOLUME TREND CHART -->
        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="18" Padding="24,20" Effect="{StaticResource CardShadow}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
              <TextBlock Text="📈 Volume Trend (Last 7 Days)" FontFamily="Segoe UI"
                FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TxtPrimary}" />
              <TextBlock Text="(USD)" FontSize="11" Foreground="{StaticResource TxtMuted}"
                Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Simple bar chart -->
            <ItemsControl x:Name="IcVolumeChart" ItemsSource="{Binding VolumeData}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="7" Rows="1" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel HorizontalAlignment="Center">
                    <Border Width="32" Height="60" Background="{StaticResource BgInput}"
                      CornerRadius="6,6,0,0" VerticalAlignment="Bottom"
                      BorderBrush="{StaticResource Border}" BorderThickness="1,1,1,0">
                      <Rectangle Width="20" HorizontalAlignment="Center"
                        VerticalAlignment="Bottom" Fill="{StaticResource Accent}"
                        RadiusX="3" RadiusY="3">
                        <Rectangle.Height>
                          <Binding Path="Height" Converter="{StaticResource PercentToHeight}" />
                        </Rectangle.Height>
                      </Rectangle>
                    </Border>
                    <TextBlock Text="{Binding Day, StringFormat='ddd'}"
                      FontSize="9" Foreground="{StaticResource TxtMuted}"
                      HorizontalAlignment="Center" Margin="0,6,0,0" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>