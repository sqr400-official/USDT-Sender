<UserControl x:Class="USDT_Sender.Views.BillingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 🎨 PALETTE - Enhanced for Modern Fintech -->
        <SolidColorBrush x:Key="BgPanel" Color="#FF13131A" />
        <SolidColorBrush x:Key="BgCard" Color="#FF18181F" />
        <SolidColorBrush x:Key="BgInput" Color="#FF1E1E28" />
        <SolidColorBrush x:Key="BgInputHover" Color="#FF23232E" />
        <SolidColorBrush x:Key="Accent" Color="#FF7B6EF6" />
        <SolidColorBrush x:Key="AccentSoft" Color="#FF9D93F8" />
        <SolidColorBrush x:Key="Green" Color="#FF2DD4BF" />
        <SolidColorBrush x:Key="Danger" Color="#FFFF5C6E" />
        <SolidColorBrush x:Key="Warning" Color="#FFFBBF24" />
        <SolidColorBrush x:Key="TxtPrimary" Color="#FFF4F4F8" />
        <SolidColorBrush x:Key="TxtSecondary" Color="#FFB0B0C8" />
        <SolidColorBrush x:Key="TxtMuted" Color="#FF6B6B88" />
        <SolidColorBrush x:Key="Border" Color="#FF252535" />
        <SolidColorBrush x:Key="Separator" Color="#FF1E1E2E" />

        <!-- 🌈 GRADIENT BACKGROUND - Deep Charcoal → Midnight Blue -->
        <LinearGradientBrush x:Key="PageGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D0D10" Offset="0.0" />
            <GradientStop Color="#12121A" Offset="0.35" />
            <GradientStop Color="#1A1A2E" Offset="0.7" />
            <GradientStop Color="#16213E" Offset="1.0" />
        </LinearGradientBrush>

        <!-- ✨ SUBTLE GLOW EFFECT for active cards -->
        <DropShadowEffect x:Key="CardShadow"
            Color="#7B6EF6"
            Direction="270"
            ShadowDepth="0"
            BlurRadius="24"
            Opacity="0.15" />
        <DropShadowEffect x:Key="InputGlow"
            Color="#2DD4BF"
            Direction="0"
            ShadowDepth="0"
            BlurRadius="12"
            Opacity="0.08" />

        <!-- FIELD LABEL -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TxtMuted}" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- SECTION HEADING -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
        </Style>

        <!-- 🔑 KEYBOX INPUT STYLE (Enhanced) -->
        <Style x:Key="KeyBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Effect" Value="{StaticResource InputGlow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center" />
                                <TextBlock x:Name="Placeholder"
                                    Text="{TemplateBinding Tag}"
                                    Foreground="{StaticResource TxtMuted}"
                                    FontFamily="Segoe UI" FontSize="14"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource Accent}" />
                                <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource BgInputHover}" />
                                <Setter TargetName="Bd" Property="Effect"
                                    Value="{StaticResource InputGlow}" />
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility"
                                    Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Legacy FieldInput alias for backward compatibility -->
        <Style x:Key="FieldInput" TargetType="TextBox" BasedOn="{StaticResource KeyBox}" />

        <!-- OTP DIGIT INPUT (unchanged, just referenced) -->
        <Style x:Key="OtpInput" TargetType="TextBox">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="60" />
            <Setter Property="MaxLength" Value="1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBO BOX (enhanced with subtle shadow) -->
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Effect" Value="{StaticResource InputGlow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                        Grid.Column="0"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False" />
                                    <TextBlock Grid.Column="1"
                                        Text="⌄"
                                        FontSize="14"
                                        Foreground="{StaticResource TxtMuted}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                    <ToggleButton Grid.ColumnSpan="2"
                                        IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Focusable="False" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Fade"
                                Placement="Bottom">
                                <Border x:Name="DropBorder"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="240"
                                    Background="#FF1E1E28"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Margin="0,4,0,0"
                                    Effect="{StaticResource CardShadow}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource Accent}" />
                                <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource BgInputHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TxtPrimary}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="FontFamily" Value="Segoe UI" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Padding" Value="14,10" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="8"
                                        Margin="6,3">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                Value="#FF252535" />
                                            <Setter Property="Foreground"
                                                Value="{StaticResource TxtPrimary}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                Value="#1A7B6EF6" />
                                            <Setter Property="Foreground"
                                                Value="{StaticResource AccentSoft}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON (enhanced with depth) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92" />

                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#7B6EF6" BlurRadius="32"
                                            Opacity="0.35" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                                <Setter Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- VALIDATION STYLES -->
        <Style x:Key="ValOk" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Green}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValErr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Danger}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <!-- 🎨 MAIN BACKGROUND with Gradient -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        Background="{StaticResource PageGradient}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="920" MaxWidth="920" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 🖼️ SUBTLE BACKGROUND IMAGE (decorative, non-intrusive) -->
            <Image Grid.ColumnSpan="3"
                Source="/USDT_Sender;component/Assets/crypto-pattern.png"
                Stretch="UniformToFill"
                Opacity="0.04"
                IsHitTestVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,-100,0,0" />

            <StackPanel Grid.Column="1" Margin="0,40,0,64">

                <!-- ✨ HERO SECTION - Enhanced with subtle depth -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Border Background="#1A7B6EF6" CornerRadius="20" Padding="10,4"
                            HorizontalAlignment="Left" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}"
                                    VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Text="SECURE CHECKOUT" FontFamily="Segoe UI"
                                    FontWeight="Bold" FontSize="10"
                                    Foreground="{StaticResource Accent}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Crypto flasher" FontFamily="Segoe UI" FontWeight="Bold"
                            FontSize="32" Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,8" />
                        <TextBlock FontFamily="Segoe UI" FontSize="13" LineHeight="22"
                            Foreground="{StaticResource TxtSecondary}">
                            Enter the details to process your USDT transaction.
                        </TextBlock>
                    </StackPanel>

                    <!-- 💰 Amount Display Card -->
                    <Border Grid.Column="1" VerticalAlignment="Center" Margin="32,0,0,0"
                        Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="18" Padding="32,22"
                        Effect="{StaticResource CardShadow}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="AMOUNT DUE" FontFamily="Segoe UI" FontSize="10"
                                FontWeight="Bold" Foreground="{StaticResource TxtMuted}"
                                HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <TextBlock x:Name="TxtHeroAmount" Text="$248.00" FontFamily="Consolas"
                                FontSize="38" FontWeight="Bold"
                                Foreground="{StaticResource TxtPrimary}"
                                HorizontalAlignment="Center" />
                            <TextBlock x:Name="TxtHeroRef" Text="REF: INV-0001"
                                FontFamily="Segoe UI" FontSize="11"
                                Foreground="{StaticResource TxtMuted}" HorizontalAlignment="Center"
                                Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 🗂️ MAIN FORM CARD - Premium layout with shadow -->
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="24" Padding="44,40"
                    Effect="{StaticResource CardShadow}">

                    <StackPanel>
                        <!-- ─────────────────────────────────
                             SECTION 1 — AMOUNT TO SEND (NEW)
                        ───────────────────────────────────── -->
                        <StackPanel Margin="0,0,0,36">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="28" Height="28" CornerRadius="8"
                                    Background="{StaticResource Accent}" Margin="0,0,12,0">
                                    <TextBlock Text="1" FontFamily="Segoe UI" FontWeight="Bold"
                                        FontSize="13" Foreground="White"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Amount Details"
                                    Style="{StaticResource SectionHeading}"
                                    VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- 🔑 NEW: Amount to Send Input -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="AMOUNT TO SEND (USD)"
                                    Style="{StaticResource FieldLabel}" />
                                <Grid>
                                    <TextBox x:Name="TxtAmountToSend"
                                        Style="{StaticResource KeyBox}"
                                        Tag="Enter amount (e.g., 100000.00)"
                                        Text="100000.00"
                                        MaxLength="12"
                                        TextChanged="TxtAmountToSend_TextChanged"
                                        PreviewTextInput="TxtAmountToSend_PreviewTextInput"
                                        DataObject.Pasting="TxtAmountToSend_Pasting" />
                                    <TextBlock Text="USD"
                                        Foreground="{StaticResource TxtMuted}"
                                        FontSize="13"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"
                                        IsHitTestVisible="False" />
                                </Grid>
                                <TextBlock x:Name="ErrAmount"
                                    Text="Please enter a valid amount greater than 0."
                                    Style="{StaticResource ValErr}" Visibility="Collapsed" />
                            </StackPanel>

                            <!-- 💡 Helper tip -->
                            <Border Background="#0D7B6EF6" BorderBrush="#207B6EF6"
                                BorderThickness="1" CornerRadius="10" Padding="14,10"
                                Margin="0,8,0,0">
                                <TextBlock FontFamily="Segoe UI" FontSize="11"
                                    Foreground="{StaticResource TxtSecondary}" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentSoft}">Tip:</Run> Amount
                                    is in USD. Final crypto amount calculated at current rate. </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,8,0,36" />

                        <!-- ─────────────────────────────────
                             SECTION 2 — CRYPTOCURRENCY
                        ───────────────────────────────────── -->
                        <StackPanel Margin="0,0,0,36">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="28" Height="28" CornerRadius="8"
                                    Background="{StaticResource Accent}" Margin="0,0,12,0">
                                    <TextBlock Text="2" FontFamily="Segoe UI" FontWeight="Bold"
                                        FontSize="13" Foreground="White"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Cryptocurrency"
                                    Style="{StaticResource SectionHeading}"
                                    VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="SELECT CRYPTOCURRENCY"
                                    Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="CmbCrypto" Style="{StaticResource FieldCombo}"
                                    SelectedIndex="3">
                                    <ComboBoxItem Content="₿  Bitcoin (BTC)" />
                                    <ComboBoxItem Content="Ξ  Ethereum (ETH)" />
                                    <ComboBoxItem Content="◎  Solana (SOL)" />
                                    <ComboBoxItem Content="◈  USDT (TRC-20)" />
                                    <ComboBoxItem Content="◈  USDT (ERC-20)" />
                                    <ComboBoxItem Content="⬡  BNB (BEP-20)" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="WALLET ADDRESS" Style="{StaticResource FieldLabel}" />
                                <Grid>
                                    <TextBox x:Name="TxtWalletAddress"
                                        Style="{StaticResource KeyBox}"
                                        Tag="Paste your wallet address here"
                                        TextChanged="TxtWallet_TextChanged" />
                                    <TextBlock x:Name="IcoWallet" Text="✓"
                                        Style="{StaticResource ValOk}" HorizontalAlignment="Right"
                                        Margin="0,0,16,0" Visibility="Collapsed" />
                                </Grid>
                                <TextBlock x:Name="ErrWallet"
                                    Text="Wallet address must be at least 26 characters."
                                    Style="{StaticResource ValErr}" Visibility="Collapsed" />
                            </StackPanel>

                            <Border Background="#0DFBBF24" BorderBrush="#33FBBF24"
                                BorderThickness="1" CornerRadius="10" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" FontSize="14"
                                        Foreground="{StaticResource Warning}"
                                        VerticalAlignment="Top" Margin="0,0,10,0" />
                                    <TextBlock FontFamily="Segoe UI" FontSize="12"
                                        Foreground="{StaticResource Warning}" TextWrapping="Wrap"
                                        MaxWidth="600">
                                        <Run FontWeight="SemiBold">Network fees apply.</Run>
                                        <Run>Ensure the correct network is selected. Funds sent to
                                            the wrong network cannot be recovered.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,8,0,36" />

                        <!-- ─────────────────────────────────
                             SECTION 3 — VERIFY & PROCEED
                        ───────────────────────────────────── -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="28" Height="28" CornerRadius="8"
                                    Background="{StaticResource Accent}" Margin="0,0,12,0">
                                    <TextBlock Text="3" FontFamily="Segoe UI" FontWeight="Bold"
                                        FontSize="13" Foreground="White"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Verify &amp; Proceed"
                                    Style="{StaticResource SectionHeading}"
                                    VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- OTP Section -->
                            <Grid Margin="0,0,0,32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="ONE-TIME PASSWORD"
                                            Style="{StaticResource FieldLabel}" Margin="0,0,10,0"
                                            VerticalAlignment="Center" />
                                        <Border x:Name="OtpBadge" Background="#1A2DD4BF"
                                            CornerRadius="10" Padding="8,3"
                                            VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtOtpStatus" Text="GENERATED"
                                                FontFamily="Segoe UI" FontWeight="Bold" FontSize="9"
                                                Foreground="{StaticResource Green}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="Otp1" Style="{StaticResource OtpInput}"
                                            Margin="0,0,8,0" Tag="1"
                                            TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                        <TextBox x:Name="Otp2" Style="{StaticResource OtpInput}"
                                            Margin="0,0,8,0" Tag="2"
                                            TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                        <TextBox x:Name="Otp3" Style="{StaticResource OtpInput}"
                                            Margin="0,0,8,0" Tag="3"
                                            TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                        <TextBox x:Name="Otp4" Style="{StaticResource OtpInput}"
                                            Margin="0,0,8,0" Tag="4"
                                            TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                        <TextBox x:Name="Otp5" Style="{StaticResource OtpInput}"
                                            Margin="0,0,8,0" Tag="5"
                                            TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                        <TextBox x:Name="Otp6" Style="{StaticResource OtpInput}"
                                            Tag="6" TextChanged="OtpDigit_TextChanged"
                                            PreviewKeyDown="OtpDigit_KeyDown" />
                                    </StackPanel>
                                    <TextBlock x:Name="ErrOtp"
                                        Text="Incorrect OTP. Please try again."
                                        Style="{StaticResource ValErr}" Visibility="Collapsed" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <TextBlock Text="Didn't receive it?" FontFamily="Segoe UI"
                                        FontSize="11" Foreground="{StaticResource TxtMuted}"
                                        Margin="0,0,0,6" />
                                    <Button x:Name="BtnResendOtp" Content="↻  Resend OTP"
                                        FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                        Foreground="{StaticResource Accent}"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Height="32" Click="BtnResendOtp_Click" />
                                    <TextBlock x:Name="TxtOtpHint" FontFamily="Consolas"
                                        FontSize="11" Foreground="{StaticResource TxtMuted}"
                                        Margin="0,6,0,0" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- ✅ PROCEED BUTTON -->
                            <Button x:Name="BtnProceed" Style="{StaticResource BtnPrimary}"
                                IsEnabled="False" Click="BtnProceed_Click" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="14" VerticalAlignment="Center"
                                        Margin="0,0,8,0" />
                                    <TextBlock Text="PROCEED TO PAYMENT" FontFamily="Segoe UI"
                                        FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>