<Window x:Class="USDT_Sender.Views.SplashScreen"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="USDT Sender"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  WindowStartupLocation="CenterScreen"
  SizeToContent="WidthAndHeight"
  Topmost="True"
  ShowInTaskbar="False"
  ResizeMode="NoResize"
  Opacity="0">

  <Window.Resources>
    <!-- 🎨 PALETTE (Consistent with BillingView/HelpSupportView) -->
    <LinearGradientBrush x:Key="PageGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0D0D10" Offset="0.0" />
      <GradientStop Color="#12121A" Offset="0.35" />
      <GradientStop Color="#1A1A2E" Offset="0.7" />
      <GradientStop Color="#16213E" Offset="1.0" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Accent" Color="#FF7B6EF6" />
    <SolidColorBrush x:Key="AccentSoft" Color="#FF9D93F8" />
    <SolidColorBrush x:Key="Green" Color="#FF2DD4BF" />
    <SolidColorBrush x:Key="TxtPrimary" Color="#FFF4F4F8" />
    <SolidColorBrush x:Key="TxtSecondary" Color="#FFB0B0C8" />
    <SolidColorBrush x:Key="TxtMuted" Color="#FF6B6B88" />

    <!-- ✨ SHADOW -->
    <DropShadowEffect x:Key="CardShadow" Color="#7B6EF6" Direction="0" ShadowDepth="0"
      BlurRadius="36" Opacity="0.28" />

    <!-- 🔄 LOADER ROTATION STORYBOARD -->
    <Storyboard x:Key="LoaderAnimation" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="RotateOuter" Storyboard.TargetProperty="Angle"
        From="0" To="360" Duration="0:0:1.2" />
      <DoubleAnimation Storyboard.TargetName="RotateInner" Storyboard.TargetProperty="Angle"
        From="360" To="0" Duration="0:0:1.8" />
    </Storyboard>

    <!-- 💫 LOGO PULSE STORYBOARD -->
    <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX"
        From="1" To="1.03" Duration="0:0:2" AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY"
        From="1" To="1.03" Duration="0:0:2" AutoReverse="True" />
    </Storyboard>
  </Window.Resources>

  <!-- Main Container with Rounded Corners -->
  <Border Background="{StaticResource PageGradient}" CornerRadius="28" Padding="72,56"
    Effect="{StaticResource CardShadow}" MinWidth="420">
    <StackPanel HorizontalAlignment="Center">

      <!-- 🪙 Animated Logo -->
      <Border Width="76" Height="76" Background="#1A7B6EF6" CornerRadius="22"
        Margin="0,0,0,28" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
          <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <TextBlock Text="◈" FontSize="38" Foreground="{StaticResource AccentSoft}"
          HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
      </Border>

      <!-- 📝 App Name & Tagline -->
      <TextBlock Text="USDT Sender" FontFamily="Segoe UI" FontWeight="Bold" FontSize="30"
        Foreground="{StaticResource TxtPrimary}" TextAlignment="Center" />
      <TextBlock Text="Secure. Instant. Decentralized." FontFamily="Segoe UI" FontSize="13"
        Foreground="{StaticResource TxtSecondary}" Margin="0,6,0,36" TextAlignment="Center" />

      <!-- 🔄 Dual-Ring Loader -->
      <Grid Width="48" Height="48" Margin="0,0,0,24">
        <!-- Outer Ring -->
        <Ellipse Width="48" Height="48" Stroke="{StaticResource Accent}" StrokeThickness="2.5"
          StrokeDashArray="1.5,1.5" RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <RotateTransform x:Name="RotateOuter" Angle="0" />
          </Ellipse.RenderTransform>
        </Ellipse>
        <!-- Inner Ring -->
        <Ellipse Width="32" Height="32" Stroke="{StaticResource Green}" StrokeThickness="2"
          StrokeDashArray="2,2" RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <RotateTransform x:Name="RotateInner" Angle="0" />
          </Ellipse.RenderTransform>
        </Ellipse>
      </Grid>

      <!-- 📊 Status Text -->
      <TextBlock x:Name="TxtStatus" Text="Initializing core modules..." FontFamily="Segoe UI"
        FontSize="12" Foreground="{StaticResource TxtMuted}" TextAlignment="Center"
        Margin="0,0,0,16" />

      <!-- 📍 Progress Dots (Visual Step Indicator) -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
        <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="{StaticResource Accent}" Margin="0,0,6,0" />
        <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="{StaticResource TxtMuted}"
          Margin="0,0,6,0" />
        <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="{StaticResource TxtMuted}"
          Margin="0,0,6,0" />
        <Ellipse x:Name="Dot4" Width="6" Height="6" Fill="{StaticResource TxtMuted}" />
      </StackPanel>

      <!-- 🏷️ Version & Build -->
      <TextBlock x:Name="TxtVersion" FontFamily="Consolas" FontSize="10"
        Foreground="{StaticResource TxtMuted}" TextAlignment="Center" Opacity="0.5" />
    </StackPanel>
  </Border>
</Window>